import string
import random
kho = string.ascii_letters + string.digits + string.punctuation
advice = ""
a= input("Vui lòng nhập mật khẩu của bạn: ")
A= any(b.isdigit() for b in a)
B= any(c.isalpha() for c in a)
for i in range(15):
    advice= advice + random.choice(kho)
if not(A and B):
    print("Mật khẩu không hợp lệ.")
    print(f"Đề xuất mật khẩu cho bạn là: {advice}")
else:
    print("Mật khẩu hợp lệ.")
    if len(a) >= 8:
        print("Mật khẩu đủ mạnh")
    else:
        print("Mật khẩu yếu.")
        print(f"Đề xuất mật khẩu cho bạn là: {advice}")

    




